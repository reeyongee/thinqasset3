      { "target": ".sd-description", "y": 24, "autoAlpha": 0, "duration": 0.7, "ease": "power2.out", "delay": 0.25, "clearProps": "transform" },
      { "target": ".sd-hero-image", "clipPath": "inset(0 0 100% 0 round 24px) → inset(0 0 0% 0 round 24px)", "duration": 1, "ease": "power3.inOut", "delay": 0.35, "clearProps": "clipPath" }
    ]

      "severity": "environmental",
      "note": "ThinqAsset nav uses glass/transparent treatment."
    },
    {
      "area": "layout",
      "property": "headerToH1 mobile",
      "reference": "34px",
      "ours": "46px",
      "severity": "minor",
      "note": "12px delta from shorter nav (64px vs 76px) with matched McShannock main offset (70px)."
    },
    {
      "area": "layout",
      "property": "h1 absolute top desktop",
      "reference": "166px",
      "ours": "136px",
      "severity": "minor",
      "note": "Adjusted article offset (40px vs 70px) to preserve 72px header→H1 gap with 64px nav."
    },
    {
      "area": "hero",
      "property": "image height desktop",
      "reference": "703.7px",
      "ours": "~810px",
      "severity": "content",
      "note": "Pillar images are ~1400×800 (1.75:1) vs McShannock 1360×787 (1.73:1); width identical at 1216px."
    },
    {
      "area": "hero",
      "property": "image source",
      "reference": "Sanity CDN product design screenshot",
      "ours": "ThinqAsset pillar PNG per service",
      "severity": "intentional",
      "note": "Correct for ThinqAsset content model."
    },
    {
      "area": "content",
      "property": "h1 line count",
      "reference": "2 lines (144px block height)",
      "ours": "1 line (72px) for shorter titles",
      "severity": "content",
      "note": "Layout tokens match; block height varies with copy."
    },
    {
      "area": "page",
      "property": "sections below landing",
      "reference": "none in landing band",
      "ours": "services-detail with back link, body, highlights",
      "severity": "intentional",
      "note": "ThinqAsset detail page continues below CRS landing."
    },
    {
      "area": "color",
      "property": "description text",
      "reference": "text-gray-400 / lab(65.93 -0.83 -8.17)",
      "ours": "#99a1af (equivalent sRGB)",
      "severity": "none",
      "note": "Visually matched."
    },
    {
      "area": "color",
      "property": "body background outside section",
      "reference": "#0a0a0a",
      "ours": "var(--ta-navy-deep) via html",
      "severity": "minor",
      "note": "Landing section itself is #000; page chrome differs."
    },
    {
      "area": "a11y",
      "property": "prefers-reduced-motion",
      "reference": "not implemented",
      "ours": "implemented in hook + CSS",
      "severity": "enhancement",
      "note": "Shows final state without tweens when reduced motion preferred."
    },
    {
      "area": "integration",
      "property": "page transitions",
      "reference": "none",
      "ours": "data-transition-page / data-transition-text on landing",
      "severity": "intentional",
      "note": "ThinqAsset soft-dissolve system per docs/page-transitions.md."
    }
